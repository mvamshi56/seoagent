    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "groq-sdk": "^1.1.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "node-fetch": "^3.3.2",
